// khonliang ecosystem — proposed architecture (first draft, 2026-04-24)
// Companion to inventory.md §7. Conservative — only shows changes with strong
// signal from the shallow pass. Deeper dedup/vestige sweeps may add more.
//
// Colour key:
//   black solid    — exists today, keep as-is
//   green          — proposed addition (new node, new edge)
//   orange dashed  — proposed move / rename / split
//   red solid      — proposed retirement (delete node, delete edge)
//   grey dotted    — existing import, informational only
//
// Node-fill colours retained from current.dot to preserve visual categories.

digraph khonliang_proposed {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=11, splines=true, nodesep=0.5, ranksep=0.8];
  node  [fontname="Helvetica", fontsize=10, style=filled, shape=box];
  edge  [fontname="Helvetica", fontsize=9];

  // ========= FRAMEWORK =========
  subgraph cluster_framework {
    label="foundational framework (legacy — partially retire / partially absorb)";
    style=dashed; color="#888888";
    node [fillcolor="#fff2cc"];

    khonliang [label="ollama-khonliang\n(import: khonliang)\n\nDECIDE per-submodule:\n  mcp.compact → hoist to bus-lib ?\n  knowledge.store → to researcher-lib ?\n  research.base / .engine → retire ?\n  consensus, debate, blackboard → keep as framework"];
  }

  // ========= LIBS =========
  subgraph cluster_libs {
    label="SDK / contract libraries";
    style=dashed; color="#888888";
    node [fillcolor="#dae8fc"];

    bus_lib [label="khonliang-bus-lib\n(import: khonliang_bus)\n\n+ mcp.compact helpers (hoisted)\n+ LocalDocReader / DocContent\n   (hoisted from researcher-lib)\n\n[refresh CLAUDE.md ecosystem diagram]"];
    researcher_lib [label="khonliang-researcher-lib\n(import: khonliang_researcher)\n\n- drop 5 backward-compat aliases\n   (ConceptNode, build_project_scores,\n    build_concept_matrix, build_concept_graph,\n    format_project_tags)\n- (optional) absorb knowledge.store / triples\n   from ollama-khonliang"];
    reviewer_lib [label="khonliang-reviewer-lib\n(import: khonliang_reviewer)\n\n(no change)"];
    librarian_lib [label="khonliang-librarian-lib ?\n\nIF librarian needs its own SDK:\n  LibrarianStore, GapReport,\n  PaperClassification, …\n  (currently in researcher-lib)", fillcolor="#d5e8d4", style="filled,dashed"];
  }

  // ========= AGENTS =========
  subgraph cluster_agents {
    label="bus-resident agents";
    style=dashed; color="#888888";
    node [fillcolor="#d5e8d4"];

    developer [label="khonliang-developer\n(import: developer)\n\n(decide) keep BaseResearchAgent\nborrow, or drop for clarity"];
    researcher [label="khonliang-researcher\n(import: researcher)\n\n- finish concept→entity rename\n- retire pre-extraction duplicates:\n   researcher/graph.py,\n   relevance.py, synthesizer.py,\n   worker.py (confirm dead)\n- stop importing legacy\n   khonliang.research.*"];
    reviewer [label="khonliang-reviewer\n(import: reviewer)\n\n(no change)"];

    librarian [label="khonliang-librarian\n\nNEW agent repo:\n  classify_paper, identify_gaps,\n  library_health, taxonomy_report,\n  promote_investigation,\n  rebuild_neighborhoods,\n  suggest_missing_nodes", fillcolor="#c2e0c2", style="filled,dashed"];
    store [label="khonliang-store\n\nNEW agent repo:\n  artifact_get / list / grep /\n  excerpt / head / tail /\n  metadata / distill\n  (currently bus-side)", fillcolor="#c2e0c2", style="filled,dashed"];
  }

  // ========= SERVICE / INFRA =========
  subgraph cluster_infra {
    label="infrastructure";
    style=dashed; color="#888888";
    node [fillcolor="#f8cecc"];

    bus [label="khonliang-bus\n(service)\n(import: bus)\n\n- shed bus_artifact_* to store agent\n- keep flows / routing / sessions"];

    scheduler [label="khonliang-scheduler\n???", fillcolor="#eeeeee", style="filled,dashed"];
  }

  // ========= EDGES: EXISTING (keep) =========
  edge [style=solid, color="#333333"];

  researcher_lib -> bus_lib     [label="runtime"];

  developer -> bus_lib          [label="runtime"];
  developer -> researcher_lib   [label="runtime"];

  researcher -> bus_lib         [label="runtime"];
  researcher -> researcher_lib  [label="runtime"];

  reviewer -> bus_lib           [label="runtime"];
  reviewer -> reviewer_lib      [label="runtime"];

  bus -> bus_lib                [label="[agents] extra", style=dashed];

  // ========= EDGES: PROPOSED ADDITIONS =========
  edge [style=solid, color="#2e7d32", fontsize=9, arrowhead=normal];

  librarian -> bus_lib          [label="NEW runtime"];
  librarian -> researcher_lib   [label="NEW runtime\n(or librarian-lib)"];

  store -> bus_lib              [label="NEW runtime"];

  // ========= EDGES: PROPOSED MOVES =========
  edge [style=dashed, color="#e65100", fontsize=9, arrowhead=normal];

  khonliang -> bus_lib          [label="MOVE  khonliang.mcp.compact\n        → khonliang_bus.mcp  (?)"];
  researcher_lib -> bus_lib     [label="MOVE  LocalDocReader, DocContent\n        → khonliang_bus (or neutral lib)"];
  khonliang -> researcher_lib   [label="MOVE  knowledge.store,\n        knowledge.triples  (?)"];

  // ========= EDGES: PROPOSED RETIREMENT =========
  edge [style=solid, color="#c62828", fontsize=9, arrowhead=odiamond];

  researcher -> khonliang       [label="RETIRE  khonliang.research.base /\n         .engine / .models\n         once researcher-lib covers"];

  // ========= EDGES: OPEN QUESTIONS =========
  edge [style=dotted, color="#5e35b1", fontsize=9, arrowhead=veevee];

  bus_lib -> scheduler          [label="REFRESH  diagram stale;\n          scheduler missing on disk"];

  // ========= LEGEND =========
  subgraph cluster_legend {
    label="legend";
    style=solid; color="#aaaaaa"; fontsize=10;
    node [shape=plaintext, fillcolor=white, style=""];

    legend [label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333">—— black solid</FONT></TD><TD ALIGN="LEFT">existing, keep</TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#2e7d32">—— green</FONT></TD><TD ALIGN="LEFT">proposed addition</TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#e65100">- - orange dashed</FONT></TD><TD ALIGN="LEFT">proposed move / hoist</TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#c62828">—◇ red</FONT></TD><TD ALIGN="LEFT">proposed retirement</TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#5e35b1">· · purple dotted</FONT></TD><TD ALIGN="LEFT">open question</TD></TR>
      </TABLE>
    >];
  }
}
