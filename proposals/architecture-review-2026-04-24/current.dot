// khonliang ecosystem — current architecture (as of 2026-04-24)
// Generated by architecture-review-2026-04-24. Factual snapshot; no proposals here.
//
// Node classes:
//   framework  — foundational libraries (widest surface)
//   lib        — SDK / contracts libraries
//   agent      — bus-resident agents (MCP-exposed)
//   service    — orchestration / transport services
//   external   — third-party dependencies we pin
//   orphan     — referenced but missing on disk
//
// Edge classes:
//   runtime    — declared in [project].dependencies (solid)
//   optional   — declared in [project.optional-dependencies] (dashed)
//   imports    — code-level `from X import ...` usage (thin)

digraph khonliang_current {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=11, splines=true, nodesep=0.5, ranksep=0.8];
  node  [fontname="Helvetica", fontsize=10, style=filled, shape=box];
  edge  [fontname="Helvetica", fontsize=9];

  // ========= FRAMEWORK =========
  subgraph cluster_framework {
    label="foundational framework (legacy)";
    style=dashed; color="#888888";
    node [fillcolor="#fff2cc"];

    khonliang [label="ollama-khonliang\n(import: khonliang)\n\nknowledge.store, .triples\nmcp.compact, .server\nresearch.base, .engine, .pool\ndigest, gateway.blackboard\nconsensus, debate, …"];
  }

  // ========= LIBS =========
  subgraph cluster_libs {
    label="SDK / contract libraries";
    style=dashed; color="#888888";
    node [fillcolor="#dae8fc"];

    bus_lib [label="khonliang-bus-lib\n(import: khonliang_bus)\n\nBaseAgent, Skill, @handler\nBusClient, Message\nadd_version_flag, resolve_version\nregistry enums (~21)"];
    researcher_lib [label="khonliang-researcher-lib\n(import: khonliang_researcher)\n\nBaseResearchAgent, DomainConfig\ngraph / entity primitives\nRelevanceScorer\nBaseQueueWorker, BaseSynthesizer\nLocalDocReader, DocContent\nVectorIndex\nlibrarian primitives"];
    reviewer_lib [label="khonliang-reviewer-lib\n(import: khonliang_reviewer)\n\nReviewFinding, ReviewRequest\nReviewResult, Severity\nReviewProvider contract\nModelPricing, estimate_api_cost"];
  }

  // ========= AGENTS =========
  subgraph cluster_agents {
    label="bus-resident agents";
    style=dashed; color="#888888";
    node [fillcolor="#d5e8d4"];

    developer [label="khonliang-developer\n(import: developer)\n\nFR / milestone / spec lifecycle\nPR watcher / fleet\nsession / repo hygiene\n~70 MCP tools"];
    researcher [label="khonliang-researcher\n(import: researcher)\n\ningest, distill, worker\nconcept / entity graph\nsynthesize, brief_on\n~55 MCP tools\n(hosts librarian sub-agent today)"];
    reviewer [label="khonliang-reviewer\n(import: reviewer)\n\nreview_pr / review_diff\nproviders: ollama, claude_cli\nrule-table, severity_floor\n5 MCP tools"];
  }

  // ========= SERVICE / INFRA =========
  subgraph cluster_infra {
    label="infrastructure";
    style=dashed; color="#888888";
    node [fillcolor="#f8cecc"];

    bus [label="khonliang-bus\n(service)\n(import: bus)\n\nFastAPI + WS\nMCP adapter\nflows, orchestrator\nartifact R/W, scheduler\nversions, webhooks"];
    scheduler [label="khonliang-scheduler\n(symlink broken — missing)", fillcolor="#eeeeee", style="filled,dashed"];
  }

  // ========= RUNTIME DEPS (pyproject [project].dependencies) =========
  edge [style=solid, color="#333333"];

  researcher_lib -> bus_lib     [label="runtime"];
  researcher_lib -> khonliang   [label="runtime (git)"];

  developer -> bus_lib          [label="runtime"];
  developer -> researcher_lib   [label="runtime"];
  developer -> khonliang        [label="runtime (git)"];

  researcher -> bus_lib         [label="runtime"];
  researcher -> researcher_lib  [label="runtime (git SHA-pinned)"];
  researcher -> khonliang       [label="runtime (git)"];

  reviewer -> bus_lib           [label="runtime"];
  reviewer -> reviewer_lib      [label="runtime (git)"];

  // ========= OPTIONAL / EXTRAS =========
  edge [style=dashed, color="#666666"];
  bus -> bus_lib                [label="[agents] extra"];

  // ========= KEY CODE-LEVEL IMPORTS (beyond what pyproject implies) =========
  // Drawn thinner — shows actually-used symbol traffic, not just declared deps.
  edge [style=dotted, color="#0088aa", fontsize=8, arrowhead=vee];

  researcher -> khonliang [label="  knowledge.store\n  knowledge.triples\n  mcp.compact\n  pool.ModelPool\n  research.base\n  gateway.blackboard\n  digest.store" constraint=false];
  developer -> researcher_lib [label="  BaseResearchAgent\n  DomainConfig\n  LocalDocReader\n  DocContent" constraint=false];

  // scheduler referenced by docs only
  edge [style=dotted, color="#cc3333", fontsize=8];
  bus_lib -> scheduler [label="  referenced in CLAUDE.md\n  (diagram stale)"];
}
